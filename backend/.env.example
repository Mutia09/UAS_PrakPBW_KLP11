# ============================
# StuntCheck Backend - .env
# Salin file ini ke .env dan isi nilainya
# ============================

# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=stuntcheck_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT Secret (ganti dengan string acak panjang)
JWT_SECRET=ganti_dengan_secret_panjang_dan_acak_minimal_32_karakter
JWT_EXPIRES_IN=7d

# Email (untuk kirim OTP lupa kata sandi)
# Gunakan Gmail App Password atau SMTP provider lain
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@gmail.com
SMTP_PASS=app_password_gmail_anda
SMTP_FROM="StuntCheck <email@gmail.com>"

# CORS - URL frontend yang diizinkan
FRONTEND_URL=http://localhost:5500
